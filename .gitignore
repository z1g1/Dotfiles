# Never commit secrets, credentials, or per-host auth tokens.
# `.secrets.example` templates are intentionally NOT matched (no leading dot-glob on the suffix).
**/.secrets
**/.credentials.json
**/settings.local.json

# Claude Code runtime / ephemeral state (not curated config)
**/.claude-temp/
**/claude-temp/
**/.obsidian/workspace.json

# OS / editor cruft
.DS_Store
*.swp
*~

# Python tooling caches (for bin/ scripts)
__pycache__/
*.pyc
.venv/
